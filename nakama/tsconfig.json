{
  "compilerOptions": {
    "target": "ES5",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outFile": "./build/index.js",
    "typeRoots": ["./node_modules"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
